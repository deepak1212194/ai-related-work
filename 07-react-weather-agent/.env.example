# ── Required ──────────────────────────────────────────────────────────
# Set at least one for online mode. Leave blank for offline mock mode.
OPENAI_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ── Optional ──────────────────────────────────────────────────────────
MAX_ITERATIONS=6
LOG_LEVEL=INFO
