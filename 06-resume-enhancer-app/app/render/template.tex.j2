% Bullet item — slightly indented, compact
\newcommand{\resumeItem}[1]{%
  \item\small{{\color{textdark}#1 \vspace{-1.5pt}}}%
}

% Four-cell experience / education heading
\newcommand{\resumeSubheading}[4]{%
  \vspace{1pt}\item
    \begin{tabular*}{0.97\textwidth}[t]{l@{\extracolsep{\fill}}r}
      {\color{primary}\textbf{#1}} & {\color{textmute}\small#2} \\
      {\color{secondary}\textit{\small#3}} & {\color{textmute}\textit{\small #4}} \\
    \end{tabular*}\vspace{-6pt}%
}

% Two-cell project heading
\newcommand{\resumeProjectHeading}[2]{%
    \item
    \begin{tabular*}{0.97\textwidth}{l@{\extracolsep{\fill}}r}
      {\color{primary}\small#1} & {\color{textmute}\small#2} \\
    \end{tabular*}\vspace{-6pt}%
}

% Group sub-heading inside an experience block (left accent bar)
\newcommand{\resumeGroupHeading}[1]{%
  \item[]\vspace{5pt}\hspace{-0.05in}%
    \textcolor{groupcol}{\rule[-0.05em]{2.5pt}{0.9em}}\hspace{7pt}%
    {\small\color{groupcol}\textbf{\textit{#1}}}\vspace{-2pt}%
}

% Thin horizontal separator between employers within same company
\newcommand{\employerSeparator}{%
  \vspace{5pt}%
  \noindent\hspace*{0.12in}%
  \textcolor{textmute!30}{\rule{0.95\textwidth}{0.25pt}}%
  \vspace{-2pt}%
}

% Achievement / certification row: chevron icon · bold title · description · year
\newcommand{\achieveRow}[3]{%
  \noindent
  \small
  \textcolor{achievecol}{\faAngleRight}\enspace
  \textbf{\color{primary}#1}\enspace
  {\color{textmute}$\cdot$}\enspace
  {\color{textmid}#2}%
  \hfill
  {\color{textmute}\textit{\small#3}}\\[4pt]%
}

