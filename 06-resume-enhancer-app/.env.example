# Copy to .env. docker-compose reads .env automatically.
# All variables are OPTIONAL - the app auto-detects whichever backend is configured.

# ----------------------------------------------------------------------
# Backend selection. Leave blank for auto-detect (recommended).
# Options: claude_code | anthropic | huggingface
# ----------------------------------------------------------------------
RESUME_LLM_BACKEND=

# ----------------------------------------------------------------------
# Option A - Claude Code (uses your Claude Code login, no API key needed)
# Requires:
#   pip install claude-agent-sdk     (already in requirements.txt)
#   claude  /  login                  (do this once in a terminal)
# Nothing else needed - the app picks this up automatically.
# ----------------------------------------------------------------------

# ----------------------------------------------------------------------
# Option B - Anthropic API (highest quality, paid per-token)
# Get a key at: https://console.anthropic.com/settings/keys
# ----------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ----------------------------------------------------------------------
# Option C - Hugging Face (free tier, lower quality)
# Get a free token at: https://huggingface.co/settings/tokens
# ----------------------------------------------------------------------
HF_API_KEY=
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct

# ----------------------------------------------------------------------
# Iteration loop tuning (optional)
# ----------------------------------------------------------------------
RESUME_MAX_ITERATIONS=3
RESUME_ACCEPT_THRESHOLD=82
RESUME_LOG_LEVEL=INFO
