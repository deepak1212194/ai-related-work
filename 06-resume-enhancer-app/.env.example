# Copy to .env. docker-compose reads .env automatically.
# All variables are OPTIONAL - the app auto-detects whichever backend is configured.

# ----------------------------------------------------------------------
# Backend selection. Leave blank for auto-detect (recommended).
# Auto-detect order: Groq → HuggingFace
# Groq is strongly preferred — free, fast, no queue.
# ----------------------------------------------------------------------
RESUME_LLM_BACKEND=

# ----------------------------------------------------------------------
# Option A - Groq (RECOMMENDED — free, fast, 14,400 req/day)
# Get a free key at: https://console.groq.com/keys  (no credit card needed)
# Auto-fallback chain: llama-4-scout-17b → llama-3.3-70b → llama-3.1-8b
# ----------------------------------------------------------------------
GROQ_API_KEY=
# Default model. Higher TPM = fewer rate-limit retries.
# Options: meta-llama/llama-4-scout-17b-16e-instruct (30K TPM, recommended)
#          llama-3.3-70b-versatile (6K TPM, highest quality)
#          llama-3.1-8b-instant    (6K TPM, fastest)
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ----------------------------------------------------------------------
# Option B - Hugging Face (free tier, slower fallback)
# Get a free token at: https://huggingface.co/settings/tokens
# ----------------------------------------------------------------------
HF_API_KEY=
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ----------------------------------------------------------------------
# Iteration loop tuning (optional)
# ----------------------------------------------------------------------
RESUME_MAX_ITERATIONS=3
RESUME_ACCEPT_THRESHOLD=82
RESUME_LOG_LEVEL=INFO

# ----------------------------------------------------------------------
# Security & rate limiting (optional)
# ----------------------------------------------------------------------
RESUME_MAX_UPLOAD_KB=512
RESUME_MAX_RUNS_PER_HOUR=1
RESUME_WORK_TTL_HOURS=2

# LLM retry settings
RESUME_LLM_MAX_RETRIES=3
RESUME_LLM_TIMEOUT_S=90

# Basic auth (set both to enable login screen)
RESUME_AUTH_USER=
RESUME_AUTH_PASS=
